generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PhotoCategory {
  MENU_ITEM
  INVENTORY
  STAFF
  FACILITY
  RECEIPT
  FOOD_PREP
  MARKETING
  MAINTENANCE
  OTHER
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  SERVED
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  DEBIT
  MOBILE
  GIFT_CARD
  OTHER
}

enum CheckStatus {
  OPEN
  PRINTED
  PARTIALLY_PAID
  PAID
  CLOSED
  NEEDS_TIP
  REFUND_VOID_NEEDED
}

enum InsightSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InsightCategory {
  INVENTORY
  STAFFING
  FINANCE
  OPERATIONS
  MENU
  CUSTOMER
  FACILITY
  GENERAL
}

enum AppRole {
  OWNER
  MANAGER
  SERVER
  KITCHEN
  HOST
}

enum SubscriptionPlan {
  STARTER
  GROWTH
  PRO
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  SNAPCHAT
  X
  YOUTUBE
  LINKEDIN
  PINTEREST
}

enum SocialPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  PARTIAL
  FAILED
}

enum PublishStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
}

enum PaymentProviderKind {
  MANUAL
  STRIPE
  SQUARE
}

enum PaymentProviderPurpose {
  SUBSCRIPTION
  POS
}

enum TipPoolMode {
  INDIVIDUAL
  FULL_POOL
  POINTS
  ROLE_WEIGHTED
}

enum PayrollRunStatus {
  DRAFT
  FINALIZED
  PAID
}

enum EwaAdvanceStatus {
  PENDING
  PAID
  DEDUCTED
  CANCELLED
}

enum ShiftSwapKind {
  SWAP
  BID
  DROP
}

enum ShiftSwapStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum ApplicationStatus {
  NEW
  SCREENING
  INTERVIEW_SCHEDULED
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

enum ApplicationSource {
  TEXT_APPLY
  WEB
  WALK_IN
  REFERRAL
}

enum SmsDirection {
  INBOUND
  OUTBOUND
}

enum OnboardingPacketStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
}

enum OnboardingDocType {
  I9
  W4
  DIRECT_DEPOSIT
}

enum TrainingModuleKind {
  COMPLIANCE
  SAFETY
  CERTIFICATION
}

enum CertAlertLevel {
  OK
  EXPIRING
  EXPIRED
  MISSING
}

enum IncidentType {
  WORKPLACE_INJURY
  GUEST_INCIDENT
  NEAR_MISS
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  CLOSED
}

enum ShiftFeedbackKind {
  NOTE
  SHOUT_OUT
  COACHING
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarUrl    String?
  role         AppRole
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  permissionOverride UserPermissionOverride?
  isPlatformAdmin Boolean @default(false)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Location {
  id            String   @id @default(cuid())
  name          String
  address       String?
  phone         String?
  seatCount     Int      @default(40)
  squareFootage Float    @default(2000)
  plan          SubscriptionPlan @default(STARTER)
  autopayEnabled Boolean  @default(false)
  billingEmail   String?
  paymentBrand   String?
  paymentLast4   String?
  paymentExpMonth Int?
  paymentExpYear  Int?
  nextBillingDate DateTime?
  setupComplete Boolean  @default(true)
  onboardingStep Int    @default(0)
  latitude       Float?
  longitude      Float?
  geoFenceRadiusM Int     @default(150)
  geoClockInRequired Boolean @default(true)
  targetLaborPct Float   @default(30)
  mealBreakMinutes Int   @default(30)
  restBreakMinutes Int   @default(10)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  menuItems        MenuItem[]
  inventoryItems   InventoryItem[]
  staffMembers     StaffMember[]
  tables           Table[]
  orders           Order[]
  expenses         Expense[]
  photos           Photo[]
  businessInsights BusinessInsight[]
  activityLogs     ActivityLog[]
  shifts           Shift[]
  users            User[]
  socialAccounts   SocialAccount[]
  socialPosts      SocialPost[]
  websiteConnection WebsiteConnection?
  marketingCampaigns MarketingCampaign[]
  guestReviews     GuestReview[]
  vendorInvoices   VendorInvoice[]
  inventoryWaste   InventoryWaste[]
  vendorPriceHistory VendorPriceHistory[]
  externalFactors  ExternalFactor[]
  rolePermissionSets RolePermissionSet[]
  userPermissionOverrides UserPermissionOverride[]
  paymentProviderConnections PaymentProviderConnection[]
  payrollSettings      PayrollSettings?
  tipPoolRuns          TipPoolRun[]
  payPeriods           PayPeriod[]
  ewaAdvances          EwaAdvance[]
  timeEntries          TimeEntry[]
  shiftSwapRequests    ShiftSwapRequest[]
  hiringSettings       HiringSettings?
  jobPostings          JobPosting[]
  applicants           Applicant[]
  applications         Application[]
  smsMessages          SmsMessage[]
  onboardingPackets    OnboardingPacket[]
  trainingSettings       TrainingSettings?
  staffCertifications  StaffCertification[]
  trainingModules      TrainingModule[]
  trainingCompletions  TrainingCompletion[]
  complianceSettings   ComplianceSettings?
  incidentReports      IncidentReport[]
  shiftFeedback        ShiftFeedback[]
  modifierGroups       ModifierGroup[]
  posCategoryStyles    PosCategoryStyle[]
  menuScheduleRules    MenuScheduleRule[]
  menuRevision         Int      @default(0)
}

model PaymentProviderConnection {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  provider    PaymentProviderKind
  purpose     PaymentProviderPurpose
  accountId   String?
  externalRef String?
  credential  String?
  status      String   @default("connected")
  metadata    String?
  connectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([locationId, purpose])
}

model RolePermissionSet {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  role        AppRole
  permissions String
  updatedAt   DateTime @updatedAt

  @@unique([locationId, role])
}

model UserPermissionOverride {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions String
  updatedAt   DateTime @updatedAt
}

model MenuItem {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  category    String
  recipeCost  Float    @default(0)
  available   Boolean  @default(true)
  stockCount  Int?
  eightySixedAt DateTime?
  imageUrl    String?
  posColor    String?
  posGridIndex Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
  modifierGroups ModifierGroup[]
}

model InventoryItem {
  id            String   @id @default(cuid())
  locationId    String
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name          String
  barcode       String?
  quantity      Float
  unit          String
  minQuantity   Float    @default(0)
  costPerUnit   Float    @default(0)
  previousCostPerUnit Float?
  portionSize   Float?
  yieldPct      Float    @default(100)
  supplier      String?
  lastRestocked DateTime?
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  wasteLogs     InventoryWaste[]

  @@unique([locationId, barcode])
}

model StaffMember {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  userId     String?  @unique
  name       String
  role       String
  email      String?
  phone      String?
  dateOfBirth DateTime?
  hourlyRate Float    @default(0)
  isTippedEmployee Boolean @default(false)
  tipPoints  Float    @default(1)
  active     Boolean  @default(true)
  hireDate   DateTime?
  terminatedAt DateTime?
  terminationReason String?
  imageUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  shifts     Shift[]
  roleRates  StaffRoleRate[]
  servedOrders Order[] @relation("OrderServer")
  tipAllocations TipPoolAllocation[]
  payrollLineItems PayrollLineItem[]
  ewaAdvances EwaAdvance[]
  timeEntries TimeEntry[]
  swapRequestsAsRequester ShiftSwapRequest[] @relation("SwapRequester")
  swapRequestsAsCounterparty ShiftSwapRequest[] @relation("SwapCounterparty")
  certifications StaffCertification[]
  trainingCompletions TrainingCompletion[]
  incidentReports IncidentReport[]
  shiftFeedback   ShiftFeedback[]
}

model Shift {
  id            String      @id @default(cuid())
  locationId    String
  location      Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  staffMemberId String?
  staffMember   StaffMember? @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  date          DateTime
  startTime     String
  endTime       String
  workRole      String?
  notes         String?
  isOpen        Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  timeEntries   TimeEntry[]
  swapRequests  ShiftSwapRequest[] @relation("SwapShift")
  offerSwapRequests ShiftSwapRequest[] @relation("SwapOffer")
  feedback      ShiftFeedback[]

  @@index([locationId, date])
  @@index([staffMemberId, date])
}

model TimeEntry {
  id              String      @id @default(cuid())
  locationId      String
  location        Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  staffMemberId   String
  staffMember     StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  userId          String?
  shiftId         String?
  shift           Shift?      @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  clockInAt       DateTime
  clockOutAt      DateTime?
  clockInLat      Float?
  clockInLng      Float?
  clockOutLat     Float?
  clockOutLng     Float?
  geoVerifiedIn   Boolean     @default(false)
  geoVerifiedOut  Boolean     @default(false)
  mealBreakTaken  Boolean?
  restBreakTaken  Boolean?
  breakAttestedAt DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([locationId, clockInAt])
  @@index([staffMemberId, clockInAt])
}

model ShiftSwapRequest {
  id                  String          @id @default(cuid())
  locationId          String
  location            Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  kind                ShiftSwapKind
  status              ShiftSwapStatus @default(PENDING)
  shiftId             String
  shift               Shift           @relation("SwapShift", fields: [shiftId], references: [id], onDelete: Cascade)
  requesterStaffId    String
  requesterStaff      StaffMember     @relation("SwapRequester", fields: [requesterStaffId], references: [id], onDelete: Cascade)
  counterpartyStaffId String?
  counterpartyStaff   StaffMember?    @relation("SwapCounterparty", fields: [counterpartyStaffId], references: [id], onDelete: SetNull)
  offerShiftId        String?
  offerShift          Shift?          @relation("SwapOffer", fields: [offerShiftId], references: [id], onDelete: SetNull)
  message             String?
  reviewedByUserId    String?
  reviewedAt          DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([locationId, status])
  @@index([requesterStaffId])
}

model HiringSettings {
  id           String   @id @default(cuid())
  locationId   String   @unique
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  applyPhone   String?
  applyKeyword String   @default("APPLY")
  smsEnabled   Boolean  @default(false)
  updatedAt    DateTime @updatedAt
}

model JobPosting {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  title       String
  role        String
  description String?
  applyCode   String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  applications Application[]

  @@unique([locationId, applyCode])
}

model Applicant {
  id           String        @id @default(cuid())
  locationId   String
  location     Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  email        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  smsMessages  SmsMessage[]

  @@unique([locationId, phone])
}

model Application {
  id            String            @id @default(cuid())
  locationId    String
  location      Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  applicantId   String
  applicant     Applicant         @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  jobPostingId  String?
  jobPosting    JobPosting?       @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)
  role          String
  source        ApplicationSource @default(WEB)
  status        ApplicationStatus @default(NEW)
  notes         String?
  appliedAt     DateTime          @default(now())
  hiredAt       DateTime?
  updatedAt     DateTime          @updatedAt
  interviews    Interview[]
  onboardingPacket OnboardingPacket?

  @@index([locationId, status])
  @@index([applicantId])
}

model Interview {
  id              String      @id @default(cuid())
  applicationId   String
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scheduledAt     DateTime
  reminderSentAt  DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model SmsMessage {
  id            String       @id @default(cuid())
  locationId    String
  location      Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  applicantId   String?
  applicant     Applicant?   @relation(fields: [applicantId], references: [id], onDelete: SetNull)
  direction     SmsDirection
  toPhone       String
  fromPhone     String
  body          String
  status        String       @default("queued")
  externalId    String?
  createdAt     DateTime     @default(now())

  @@index([locationId, applicantId])
  @@index([toPhone])
}

model OnboardingPacket {
  id             String                 @id @default(cuid())
  locationId     String
  location       Location               @relation(fields: [locationId], references: [id], onDelete: Cascade)
  applicationId  String                 @unique
  application    Application            @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  token          String                 @unique
  status         OnboardingPacketStatus @default(PENDING)
  staffMemberId  String?
  completedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  documents      OnboardingDocument[]
  acknowledgments HandbookAcknowledgment[]
}

model OnboardingDocument {
  id            String            @id @default(cuid())
  packetId      String
  packet        OnboardingPacket  @relation(fields: [packetId], references: [id], onDelete: Cascade)
  docType       OnboardingDocType
  data          String
  signatureName String?
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([packetId, docType])
}

model HandbookAcknowledgment {
  id            String           @id @default(cuid())
  packetId      String
  packet        OnboardingPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
  policyKey     String
  policyTitle   String
  signatureName String
  signedAt      DateTime         @default(now())

  @@unique([packetId, policyKey])
}

model StaffRoleRate {
  id            String      @id @default(cuid())
  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  role          String
  hourlyRate    Float
  tipPoints     Float       @default(1)
  isTippedRole  Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([staffMemberId, role])
}

model PayrollSettings {
  id                      String      @id @default(cuid())
  locationId              String      @unique
  location                Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  minimumWage             Float       @default(7.25)
  tipCredit               Float       @default(5.12)
  tippedMinCashWage       Float       @default(2.13)
  weeklyOtThresholdHours  Float       @default(40)
  dailyOtThresholdHours   Float?
  otMultiplier            Float       @default(1.5)
  useBlendedOtRate        Boolean     @default(true)
  splitShiftEnabled       Boolean     @default(false)
  splitShiftPremiumHours  Float       @default(1)
  splitShiftMinGapMinutes Int         @default(60)
  tipPoolMode             TipPoolMode @default(INDIVIDUAL)
  tipPoolRoles            String?
  ewaEnabled              Boolean     @default(false)
  ewaMaxPercent           Float       @default(50)
  ewaMaxPerAdvance        Float       @default(200)
  ewaFeeFlat              Float       @default(0)
  payPeriodDays           Int         @default(14)
  updatedAt               DateTime    @updatedAt
}

model TipPoolRun {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  periodStart DateTime
  periodEnd   DateTime
  totalTips   Float
  mode        TipPoolMode
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  allocations TipPoolAllocation[]
}

model TipPoolAllocation {
  id              String      @id @default(cuid())
  tipPoolRunId    String
  tipPoolRun      TipPoolRun  @relation(fields: [tipPoolRunId], references: [id], onDelete: Cascade)
  staffMemberId   String
  staffMember     StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  hoursWorked     Float
  tipPoints       Float
  sharePercent    Float
  tipsAmount      Float
  tipCreditMakeup Float       @default(0)

  @@index([tipPoolRunId])
}

model PayPeriod {
  id          String           @id @default(cuid())
  locationId  String
  location    Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime
  status      PayrollRunStatus @default(DRAFT)
  createdAt   DateTime         @default(now())
  runs        PayrollRun[]
  ewaAdvances EwaAdvance[]

  @@index([locationId, startDate])
}

model PayrollRun {
  id          String           @id @default(cuid())
  payPeriodId String
  payPeriod   PayPeriod        @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
  locationId  String
  status      PayrollRunStatus @default(DRAFT)
  finalizedAt DateTime?
  createdAt   DateTime         @default(now())
  lineItems   PayrollLineItem[]
}

model PayrollLineItem {
  id                String      @id @default(cuid())
  payrollRunId      String
  payrollRun        PayrollRun  @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  staffMemberId     String
  staffMember       StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  regularHours      Float
  overtimeHours     Float
  splitShiftHours   Float       @default(0)
  regularPay        Float
  overtimePay       Float
  splitShiftPay     Float       @default(0)
  tipsAllocated     Float       @default(0)
  tipCreditMakeup   Float       @default(0)
  grossPay          Float
  ewaDeductions     Float       @default(0)
  netPay            Float
  rateBreakdown     String?

  @@index([payrollRunId])
}

model EwaAdvance {
  id              String           @id @default(cuid())
  locationId      String
  location        Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  staffMemberId   String
  staffMember     StaffMember      @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  payPeriodId     String?
  payPeriod       PayPeriod?       @relation(fields: [payPeriodId], references: [id], onDelete: SetNull)
  amount          Float
  fee             Float            @default(0)
  status          EwaAdvanceStatus @default(PENDING)
  earnedAtRequest Float
  requestedAt     DateTime         @default(now())
  paidAt          DateTime?

  @@index([locationId, staffMemberId])
}

model Table {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  number     Int
  capacity   Int      @default(4)
  status     String   @default("available")
  createdAt  DateTime @default(now())
  orders     Order[]
}

model Order {
  id                String      @id @default(cuid())
  locationId        String
  location          Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  tableId           String?
  table             Table?      @relation(fields: [tableId], references: [id])
  serverStaffId     String?
  serverStaff       StaffMember? @relation("OrderServer", fields: [serverStaffId], references: [id], onDelete: SetNull)
  status            OrderStatus @default(PENDING)
  totalAmount       Float       @default(0)
  guestCount        Int         @default(1)
  channel           String      @default("dine-in")
  discountAmount    Float       @default(0)
  compAmount        Float       @default(0)
  voidAmount        Float       @default(0)
  ticketTimeMinutes Int?
  notes             String?
  partyName         String?
  checkStatus       CheckStatus @default(OPEN)
  printedAt         DateTime?
  discountReason    String?
  paidAt            DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  items             OrderItem[]
  payments          OrderPayment[]
  checks            OrderCheck[]
}

model OrderCheck {
  id         String         @id @default(cuid())
  orderId    String
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  label      String
  seatNumber Int?
  isClosed   Boolean        @default(false)
  createdAt  DateTime       @default(now())
  items      OrderItem[]
  payments   OrderPayment[]

  @@index([orderId])
}

model OrderPayment {
  id        String        @id @default(cuid())
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  checkId   String?
  check     OrderCheck?   @relation(fields: [checkId], references: [id], onDelete: SetNull)
  method    PaymentMethod
  amount    Float
  tipAmount Float         @default(0)
  reference String?
  createdAt DateTime      @default(now())

  @@index([orderId])
  @@index([checkId])
}

model OrderItem {
  id              String      @id @default(cuid())
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId      String
  menuItem        MenuItem    @relation(fields: [menuItemId], references: [id])
  quantity        Int         @default(1)
  price           Float
  seatNumber      Int?
  checkId         String?
  check           OrderCheck? @relation(fields: [checkId], references: [id], onDelete: SetNull)
  modifiers       String?
  modifierSummary String?
  kitchenStatus   String      @default("PENDING")
  firedAt         DateTime?
}

model Expense {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  description String
  amount      Float
  category    String
  date        DateTime @default(now())
  receiptUrl  String?
  createdAt   DateTime @default(now())
}

model Photo {
  id          String        @id @default(cuid())
  locationId  String
  location    Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  filename    String
  url         String
  category    PhotoCategory @default(OTHER)
  title       String?
  description String?
  tags        String?
  aiAnalysis  String?
  entityType  String?
  entityId    String?
  createdAt   DateTime      @default(now())
}

model BusinessInsight {
  id           String          @id @default(cuid())
  locationId   String
  location     Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  title        String
  description  String
  category     InsightCategory @default(GENERAL)
  severity     InsightSeverity @default(MEDIUM)
  actionable   String?
  resolved     Boolean         @default(false)
  dataSnapshot String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model ActivityLog {
  id         String   @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  action     String
  entity     String
  entityId   String?
  details    String?
  createdAt  DateTime @default(now())
}

model SocialAccount {
  id           String         @id @default(cuid())
  locationId   String
  location     Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  platform     SocialPlatform
  accountName  String
  accountId    String?
  profileUrl   String?
  followers    Int            @default(0)
  connected    Boolean        @default(true)
  lastSyncedAt DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  postTargets  SocialPostTarget[]

  @@unique([locationId, platform])
}

model WebsiteConnection {
  id            String   @id @default(cuid())
  locationId    String   @unique
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  url           String
  connected     Boolean  @default(true)
  visitors30d   Int      @default(0)
  pageViews30d  Int      @default(0)
  sessions30d   Int      @default(0)
  bounceRate    Float    @default(0)
  avgSessionSec Int      @default(0)
  topPages      String?
  referrers     String?
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SocialPost {
  id           String           @id @default(cuid())
  locationId   String
  location     Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  content      String
  mediaUrl     String?
  status       SocialPostStatus @default(DRAFT)
  scheduledFor DateTime?
  publishedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  targets      SocialPostTarget[]
}

model SocialPostTarget {
  id             String        @id @default(cuid())
  postId         String
  post           SocialPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  accountId      String
  account        SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  status         PublishStatus @default(PENDING)
  externalPostId String?
  externalUrl    String?
  errorMessage   String?
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([postId, accountId])
}

model MarketingCampaign {
  id                 String   @id @default(cuid())
  locationId         String
  location           Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name               String
  channel            String
  spend              Float    @default(0)
  impressions        Int      @default(0)
  clicks             Int      @default(0)
  conversions        Int      @default(0)
  revenueAttributed  Float    @default(0)
  startDate          DateTime
  endDate            DateTime?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
}

model GuestReview {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  source      String
  rating      Float
  comment     String?
  category    String?
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model VendorInvoice {
  id            String   @id @default(cuid())
  locationId    String
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  vendor        String
  amount        Float
  category      String
  invoiceDate   DateTime @default(now())
  priceChangePct Float   @default(0)
  createdAt     DateTime @default(now())
}

model VendorPriceHistory {
  id            String   @id @default(cuid())
  locationId    String
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  vendor        String
  itemName      String
  category      String
  unitPrice     Float
  unit          String   @default("lbs")
  effectiveDate DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([locationId, vendor, itemName])
  @@index([locationId, effectiveDate])
}

model InventoryWaste {
  id              String         @id @default(cuid())
  locationId      String
  location        Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  itemName        String
  quantity        Float
  unit            String
  cost            Float
  reason          String
  date            DateTime       @default(now())
  createdAt       DateTime       @default(now())
}

model ExternalFactor {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  date        DateTime
  factorType  String
  description String
  impactPct   Float    @default(0)
  createdAt   DateTime @default(now())
}

model TrainingSettings {
  id                 String   @id @default(cuid())
  locationId         String   @unique
  location           Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  expirationWarnDays Int      @default(30)
  updatedAt          DateTime @updatedAt
}

model StaffCertification {
  id                String   @id @default(cuid())
  locationId        String
  location          Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  staffMemberId     String
  staffMember       StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  certType          String
  issuer            String?
  certificateNumber String?
  issuedAt          DateTime?
  expiresAt         DateTime?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([locationId, expiresAt])
  @@index([staffMemberId])
}

model TrainingModule {
  id               String             @id @default(cuid())
  locationId       String
  location         Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  moduleKey        String
  title            String
  kind             TrainingModuleKind @default(COMPLIANCE)
  summary          String
  content          String
  estimatedMinutes Int                @default(15)
  required         Boolean            @default(true)
  renewalMonths    Int?
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  completions      TrainingCompletion[]

  @@unique([locationId, moduleKey])
}

model TrainingCompletion {
  id            String         @id @default(cuid())
  locationId    String
  location      Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  moduleId      String
  module        TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  staffMemberId String
  staffMember   StaffMember    @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  completedAt   DateTime       @default(now())
  score         Int?
  signatureName String?
  expiresAt     DateTime?
  createdAt     DateTime       @default(now())

  @@index([staffMemberId, moduleId])
  @@index([locationId, expiresAt])
}

model ComplianceSettings {
  id                       String   @id @default(cuid())
  locationId               String   @unique
  location                 Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  minorBlockScheduling     Boolean  @default(true)
  minorSchoolNightEndHour  Int      @default(22)
  minorSchoolNightDays     String   @default("0,1,2,3,4")
  minorMaxWeeklyHoursSchool Float   @default(18)
  minorMaxDailyHoursSchool  Float   @default(6)
  schoolCalendarActive     Boolean  @default(true)
  updatedAt                DateTime @updatedAt
}

model IncidentReport {
  id              String           @id @default(cuid())
  locationId      String
  location        Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  reportedAt      DateTime         @default(now())
  incidentType    IncidentType
  category        String
  description     String
  staffMemberId   String?
  staffMember     StaffMember?     @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  guestName       String?
  severity        IncidentSeverity @default(MEDIUM)
  oshaRecordable  Boolean          @default(false)
  actionTaken     String?
  witnessNotes    String?
  status          IncidentStatus   @default(OPEN)
  reportedByName  String?
  closedAt        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([locationId, reportedAt])
  @@index([locationId, status])
}

model ShiftFeedback {
  id            String            @id @default(cuid())
  locationId    String
  location      Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  staffMemberId String
  staffMember   StaffMember       @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  shiftId       String?
  shift         Shift?            @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  authorUserId  String?
  authorName    String
  kind          ShiftFeedbackKind @default(NOTE)
  content       String
  createdAt     DateTime          @default(now())

  @@index([staffMemberId, createdAt])
  @@index([locationId, createdAt])
  @@index([shiftId])
}

model ModifierGroup {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  categories  String?
  menuItemId  String?
  menuItem    MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  required    Boolean  @default(false)
  minSelect   Int      @default(1)
  maxSelect   Int      @default(1)
  sortOrder   Int      @default(0)
  options     ModifierOption[]

  @@index([locationId, menuItemId])
}

model ModifierOption {
  id         String        @id @default(cuid())
  groupId    String
  group      ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name       String
  priceDelta Float         @default(0)
  sortOrder  Int           @default(0)
  isDefault  Boolean       @default(false)
}

model PosCategoryStyle {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  category   String
  color      String
  icon       String?

  @@unique([locationId, category])
}

enum MenuScheduleMode {
  SHOW_CATEGORIES
  HIDE_CATEGORIES
  HAPPY_HOUR
}

model MenuScheduleRule {
  id              String           @id @default(cuid())
  locationId      String
  location        Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name            String
  mode            MenuScheduleMode
  categories      String
  daysOfWeek      String           @default("0,1,2,3,4,5,6")
  startTime       String
  endTime         String
  priceMultiplier Float            @default(1)
  active          Boolean          @default(true)
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([locationId, active])
}
